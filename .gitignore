# Local editor and environment files
.DS_Store
.idea
.vscode
.env

# Rust build output
/target

# Generated runtime state
workspace/logs/*
!workspace/logs/.gitkeep
workspace/processing/*
!workspace/processing/.gitkeep
workspace/done/*
!workspace/done/.gitkeep
workspace/review/*
!workspace/review/.gitkeep
workspace/archive/*
